{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "strict": true,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "outDir": "./dist"
  },
  "paths": {
    "@repo/shared/schemas": ["../../packages/shared/src/schemas/index.ts"],
    "@repo/shared/schemas/*": ["../../packages/shared/src/schemas/*.ts"]
  },
  "exclude": ["node_modules"]
}
